generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostType {
  NEWS
  BLOG
  PREDICTION
}

enum PublishStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  role         String    @default("EDITOR")
  avatarUrl    String?
  bio          String?
  posts        Post[]
  passwordHash String    @default("")
  sessions     Session[]
  comments     Comment[]
  createdAt    DateTime  @default(now())
}

model Category {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  posts Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  posts Post[]
}

enum TrustLevel {
  CONFIRMED
  REPORT
  RUMOR
}

model Post {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  excerpt       String?
  content       String        @db.Text
  featuredImage String?
  type          PostType      @default(NEWS)
  status        PublishStatus @default(DRAFT)
  trustLevel    TrustLevel    @default(REPORT)
  citations     Json?
  
  authorId      String
  author        User          @relation(fields: [authorId], references: [id])
  
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  
  tags          Tag[]
  
  prediction    Prediction?
  comments      Comment[]
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  publishedAt   DateTime?

  @@index([slug])
  @@index([publishedAt])
}

model Prediction {
  id               String @id @default(cuid())
  postId           String @unique
  post             Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  fighterA         String
  fighterB         String
  
  fighterAId       String?
  fighterBId       String?
  fighterARel      Fighter? @relation("FighterA", fields: [fighterAId], references: [id], onDelete: SetNull)
  fighterBRel      Fighter? @relation("FighterB", fields: [fighterBId], references: [id], onDelete: SetNull)

  eventId          String?
  event            Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  winner           String
  method           String
  predictedRound   String?
  confidenceScore  Int
  keyReasoning     String @db.Text

  actualWinner     String?
  actualMethod     String?
  actualRound      String?
  isCorrect        Boolean?
  resolvedAt       DateTime?
}

model Fighter {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  weightClass String
  record      String   
  stance      String?
  team        String?
  imageUrl    String?
  bio         String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  predictionsAsA Prediction[] @relation("FighterA")
  predictionsAsB Prediction[] @relation("FighterB")
  eventsAsA      Event[]      @relation("EventFighterA")
  eventsAsB      Event[]      @relation("EventFighterB")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Event {
  id         String   @id @default(cuid())
  fighterA   String
  fighterB   String
  
  fighterAId String?
  fighterBId String?
  fighterARel Fighter? @relation("EventFighterA", fields: [fighterAId], references: [id], onDelete: SetNull)
  fighterBRel Fighter? @relation("EventFighterB", fields: [fighterBId], references: [id], onDelete: SetNull)

  event      String
  date       String
  createdAt  DateTime @default(now())

  predictions Prediction[]
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Comment {
  id         String   @id @default(cuid())
  authorName String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}


